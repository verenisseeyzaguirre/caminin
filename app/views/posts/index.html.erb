<nav class="camino-tabs">
  <%= link_to "Todos", posts_path, class: (@listing == :all ? "is-active" : "") %>
  <%= link_to "Mis avances", mine_posts_path, class: (@listing == :mine ? "is-active" : "") %>
  <%= link_to "Nuevo avance", new_post_path %>
</nav>

<div class="camino-filters">
  <strong>Etiqueta:</strong>
  <% active = params[:tag].blank? %>
  <%= link_to "Todas", posts_path_for_listing, class: (active ? "is-active" : "") %>
  <% Post::TAGS.each do |tag| %>
    <% active_tag = params[:tag] == tag %>
    <%= link_to tag_label(tag), posts_path_for_listing(tag), class: (active_tag ? "is-active" : "") %>
  <% end %>
</div>

<% @posts.each do |post| %>
  <article class="camino-card">
    <% if current_user&.admin? %>
      <div class="camino-card-actions">
        <%= button_to "×", post_path(post), method: :delete, data: { turbo_confirm: "¿Estás segura?" }, class: "camino-btn-remove", title: "Eliminar" %>
      </div>
    <% end %>

    <h2 class="camino-card-title">
      <%= post.title %>
      <% if post.tag.present? %>
        <span class="camino-card-tag"><%= tag_label(post.tag) %></span>
      <% end %>
    </h2>
    <p class="camino-card-content"><%= post.content %></p>
    <p class="camino-card-author">Por <%= post.user.first_name %> <%= post.user.last_name %></p>

    <div class="camino-card-reactions">
      <% counts = reaction_counts(post) %>
      <% if counts.any? %>
        <span class="reaction-counters">
          <% %w[seed strength clover].each do |kind| %>
            <% n = counts[kind].to_i %>
            <% next if n.zero? %>
            <span title="<%= kind.humanize %>"><%= reaction_labels[kind] %> <%= n %></span>
          <% end %>
        </span>
      <% end %>
      <% if user_signed_in? %>
        <div data-controller="reactions" style="position: relative; display: inline-block;">
          <button type="button"
                  data-action="click->reactions#toggle"
                  class="camino-reaction-trigger"
                  aria-label="Reaccionar">
            ✨
          </button>
          <div data-reactions-target="menu"
               class="hidden reaction-menu">
            <%= button_to "🌱", post_reactions_path(post, kind: "seed"), method: :post %>
            <%= button_to "💪", post_reactions_path(post, kind: "strength"), method: :post %>
            <%= button_to "🍀", post_reactions_path(post, kind: "clover"), method: :post %>
          </div>
        </div>
      <% end %>
    </div>
  </article>
<% end %>
